# Redink environment
# Copy to .env and fill in; `redink init` will write most of these for you.

# --- Core ---
REDINK_HOME=~/.redink
REDINK_LOG_LEVEL=INFO
REDINK_API_URL=http://localhost:8080

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=redink
POSTGRES_USER=redink
POSTGRES_PASSWORD=redink
DATABASE_URL=postgresql+psycopg://redink:redink@postgres:5432/redink

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Engine ---
# One of: ollama | claude-code | copilot | anthropic | openai
REDINK_ENGINE=ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_MAX_PARALLEL=2
# Optional fallbacks (only needed for the corresponding engine)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- GitHub ---
# POC path: set GITHUB_PAT (classic or fine-grained). PR comments post as the
# PAT owner, no webhook signing required. Skips the App-install dance.
# https://github.com/settings/tokens  → scopes: repo (classic) or "Pull requests: R/W,
# Contents: R, Issues: R, Metadata: R" (fine-grained on the target repo).
GITHUB_PAT=

# Production path: GitHub App (bot attribution + webhook signing + M3 reply loop).
# Leave blank when GITHUB_PAT is set.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=

# --- Slack App ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_REVIEW_CHANNEL=redink-reviews

# --- Context providers (all optional; blank = disabled) ---

# Atlassian (Jira + Confluence Cloud). One API token works for both products —
# generate it at https://id.atlassian.com/manage-profile/security/api-tokens
# and paste it here. You only need to fill the JIRA_* / CONFLUENCE_* fields
# below if your Jira and Confluence use different accounts or hosts.
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=

# Jira — only the base URL is required when ATLASSIAN_EMAIL/TOKEN are set.
JIRA_BASE_URL=

# Confluence — include /wiki in the URL for Cloud.
CONFLUENCE_BASE_URL=

# Per-product overrides — only set these if Jira and Confluence use different
# accounts than the shared ATLASSIAN_* pair above.
JIRA_EMAIL=
JIRA_API_TOKEN=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# --- Safety ---
REDINK_ALLOW_EXTERNAL_LLM=false
REDINK_MAX_CLARIFICATION_ROUNDS=3
REDINK_MAX_COMMENT_ENGAGEMENT_ROUNDS=3
REDINK_PER_PR_TOKEN_CEILING=200000
REDINK_PER_PR_WALL_CLOCK_CEILING_S=600
REDINK_CONTEXT_CHUNK_TOKEN_BUDGET=1500
